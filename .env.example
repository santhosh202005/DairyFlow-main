# =============================================
# DairyFlow — Environment Variables
# Copy this file to .env.local and fill in values
# =============================================

# Admin Login Credentials (CHANGE THESE!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Gemini API Key (for AI features)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (Render sets this automatically)
PORT=3000

# Node Environment
NODE_ENV=production

# Database path
# Local: dairy.db
# Render: /var/data/dairy.db  (persistent disk)
DB_PATH=dairy.db

# Play Store TWA (only needed for Android app publishing)
TWA_PACKAGE_NAME=com.yourname.dairyflow
TWA_FINGERPRINT=YOUR_SHA256_CERT_FINGERPRINT_HERE

# Admin Credentials (CHANGE THESE BEFORE DEPLOYING!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Gemini API Key (optional - for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Server Port (optional, defaults to 3000)
PORT=3000

# Node environment
NODE_ENV=production

# Database path (for cloud deployment with persistent volume)
DB_PATH=dairy.db

# Play Store TWA (Trusted Web Activity) — fill these when submitting to Play Store
TWA_PACKAGE_NAME=com.yourname.dairyflow
TWA_FINGERPRINT=YOUR_SHA256_CERT_FINGERPRINT_HERE
